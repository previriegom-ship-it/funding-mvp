# Anthropic API key — get yours at https://console.anthropic.com
# Railway: set this in Variables tab
ANTHROPIC_API_KEY=sk-ant-...

# Port (Railway sets this automatically via $PORT env var)
PORT=3000

# Comma-separated list of allowed origins (NO trailing slash)
# LOCAL: http://localhost:3000,http://localhost:5500
# RAILWAY: https://your-railway-domain.railway.app,https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
