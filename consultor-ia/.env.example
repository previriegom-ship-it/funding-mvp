# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Port the server listens on (Railway sets this automatically)
PORT=3000

# Comma-separated list of allowed origins (no trailing slash)
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
